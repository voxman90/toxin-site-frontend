{
  "name": "toxin-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:api-types": "openapi-typescript ../toxin-site-backend/openapi.json -o ./src/@types/api/api.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@react-aria/focus": "^3.22.1",
    "@react-aria/interactions": "^3.28.1",
    "@reduxjs/toolkit": "^2.12.0",
    "axios": "^1.17.0",
    "axios-retry": "^4.5.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "inputmask": "^5.0.9",
    "lodash.debounce": "^4.0.8",
    "motion": "^12.40.0",
    "react": "^19.2.7",
    "react-aria": "^3.49.0",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.77.0",
    "react-i18next": "^17.0.8",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.17.0",
    "react-spinners": "^0.17.0",
    "react-toastify": "^11.1.0",
    "sass": "^1.100.0",
    "yup": "^1.7.1"
